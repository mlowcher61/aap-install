# This file is generated by the aap-install setup playbook.
# It overwrites the inventory-growth file bundled with the AAP software.

# Single-node growth topology — all components on one host.

[automationgateway]
{{ controller_url }} ansible_connection=local

[automationcontroller]
{{ controller_url }} ansible_connection=local

[automationhub]
{{ controller_url }} ansible_connection=local

[automationeda]
{{ controller_url }} ansible_connection=local

[database]
{{ controller_url }} ansible_connection=local

[all:vars]

# Bundled install — use the bundle directory shipped with the software
bundle_install=true
bundle_dir={{ aap_bundle_dir }}/bundle

# Red Hat registry credentials
registry_url='registry.redhat.io'
registry_username={{ registry_username }}
registry_password={{ registry_password }}

# Redis
redis_mode=standalone

# PostgreSQL admin credentials
postgresql_admin_username={{ postgresql_admin_username }}
postgresql_admin_password={{ postgresql_admin_password }}

# Automation Gateway
gateway_admin_password={{ gateway_admin_password }}
gateway_pg_host={{ controller_url }}
gateway_pg_database=automationgateway
gateway_pg_username=automationgateway
gateway_pg_password={{ gateway_pg_password }}

# Automation Controller
controller_admin_password={{ controller_admin_password }}
controller_pg_host={{ controller_url }}
controller_pg_database=awx
controller_pg_username=awx
controller_pg_password={{ controller_pg_password }}

# Automation Hub
hub_admin_password={{ hub_admin_password }}
hub_pg_host={{ controller_url }}
hub_pg_database=automationhub
hub_pg_username=automationhub
hub_pg_password={{ hub_pg_password }}

# Event-Driven Ansible
eda_admin_password={{ eda_admin_password }}
eda_pg_host={{ controller_url }}
eda_pg_database=automationedacontroller
eda_pg_username=automationedacontroller
eda_pg_password={{ eda_pg_password }}
